# ── 로컬 개발 ──────────────────────────────────────────
PORT=3001
CLIENT_ORIGIN=http://localhost:3000

DB_HOST=localhost
DB_PORT=3306
DB_SOCKET=/tmp/mysql.sock
DB_USER=root
DB_PASSWORD=
DB_NAME=geumso_pae
DB_SSL=false

JWT_SECRET=change-this-jwt-secret-in-production
JWT_EXPIRES_IN=7d

# ── Render + Railway 배포 시 (아래 중 하나 선택) ───────
# Render가 자동으로 PORT를 주입합니다. PORT는 직접 설정하지 않아도 됩니다.

# [방법 A] Railway MySQL 연결 URL 한 줄 (권장)
# DATABASE_URL=mysql://user:password@host:port/railway

# [방법 B] 개별 변수
# DB_HOST=containers-us-west-xxx.railway.app
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your-password
# DB_NAME=railway
# DB_SSL=true
# DB_SOCKET=   ← 배포 시 비워두거나 설정하지 않음

# Vercel 프론트 주소 (복수 가능, 쉼표 구분)
# CLIENT_ORIGIN=https://spend-insight.vercel.app,https://spend-insight-xxx.vercel.app

# NODE_ENV=production
